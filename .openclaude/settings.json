{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:\\Users\\Cyber\\Desktop\\Portifolio"],
      "disabled": false,
      "alwaysAllow": ["read_file", "read_directory", "search"]
    },
    "git": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"],
      "disabled": false,
      "alwaysAllow": ["read_commit", "read_branch", "read_status"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabled": true,
      "note": "Configure GITHUB_TOKEN environment variable to enable"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "disabled": false
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "disabled": true,
      "note": "Browser automation for testing - enable when needed"
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "disabled": false
    }
  },
  "permissions": {
    "allow": [
      "Bash(dir:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Write(./src/**)",
      "Read(./src/**)",
      "Edit(./src/**)",
      "Glob(**/*.{ts,tsx,js,jsx,css,json})"
    ]
  },
  "hooks": {}
}
